generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

enum ResourceType {
  VIDEO
  ARTICLE
  BOOK
  COURSE
}

model User {
  id              Int       @id @default(autoincrement())
  username        String
  email           String
  hashed_password String
  photoUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
}

model LearningResource {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  url         String       @unique
  type        ResourceType
  image       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @updatedAt
}
