# Database Configuration
# URL para conexión directa (usado en desarrollo y migraciones)
DIRECT_URL="postgresql://usuario:contraseña@localhost:5432/nombre_db"

# URL con connection pooling (recomendado para producción)
# DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db?pgbouncer=true"

# JWT Configuration
JWT_SECRET="tu-secreto-super-seguro-aqui"

# Server Configuration
PORT=3000
NODE_ENV=production
